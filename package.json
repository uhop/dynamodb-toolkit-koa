{
  "name": "dynamodb-toolkit-koa",
  "version": "0.2.0",
  "description": "Koa adapter for dynamodb-toolkit — mounts the standard REST route pack as Koa middleware.",
  "type": "module",
  "main": "./src/index.js",
  "module": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": "./src/index.js",
    "./*": "./src/*"
  },
  "scripts": {
    "test": "tape6 --flags FO",
    "test:bun": "tape6-bun --flags FO",
    "test:deno": "tape6-deno --flags FO",
    "ts-test": "tape6 --flags FO tests/test-*.*ts",
    "ts-test:bun": "tape6-bun --flags FO tests/test-*.*ts",
    "ts-test:deno": "tape6-deno --flags FO tests/test-*.*ts",
    "ts-check": "tsc --noEmit",
    "js-check": "tsc --project tsconfig.check.json",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write ."
  },
  "tape6": {
    "tests": [
      "/tests/test-*.js",
      "/tests/test-*.mjs"
    ],
    "node": [
      "/tests/test-*.cjs"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uhop/dynamodb-toolkit-koa.git"
  },
  "keywords": [
    "aws",
    "dynamodb",
    "aws-sdk",
    "aws-sdk-v3",
    "koa",
    "koa-middleware",
    "rest",
    "adapter",
    "dynamodb-toolkit",
    "crud",
    "pagination",
    "hooks",
    "http",
    "typescript",
    "esm",
    "zero-dependencies",
    "deno",
    "bun",
    "toolkit",
    "middleware"
  ],
  "author": "Eugene Lazutkin <eugene.lazutkin@gmail.com> (http://lazutkin.com)",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/uhop/dynamodb-toolkit-koa/issues"
  },
  "homepage": "https://github.com/uhop/dynamodb-toolkit-koa#readme",
  "funding": "https://github.com/sponsors/uhop",
  "llms": "https://raw.githubusercontent.com/uhop/dynamodb-toolkit-koa/master/llms.txt",
  "llmsFull": "https://raw.githubusercontent.com/uhop/dynamodb-toolkit-koa/master/llms-full.txt",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "dynamodb-toolkit": "^3.1.2",
    "koa": "^2.15.0 || ^3.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-dynamodb": "^3.1031.0",
    "@aws-sdk/lib-dynamodb": "^3.1031.0",
    "@types/koa": "^3.0.2",
    "@types/node": "^25.6.0",
    "dynamodb-toolkit": "^3.1.2",
    "koa": "^3.0.0",
    "prettier": "^3.8.1",
    "tape-six": "^1.7.13",
    "typescript": "^6.0.3"
  },
  "files": [
    "src",
    "llms.txt",
    "llms-full.txt"
  ]
}
